{
  "name": "@discord2/desktop",
  "version": "0.3.4",
  "description": "Discord2 self-hosted desktop client",
  "author": {
    "name": "Discord2",
    "email": "contact@discord2.local"
  },
  "homepage": "https://github.com/discord2/discord2",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@discord2/config": "0.1.0",
    "@discord2/e2ee": "0.1.0",
    "@discord2/shared": "0.1.0",
    "@supabase/supabase-js": "^2.86.0",
    "@tanstack/react-query": "^5.90.12",
    "livekit-client": "^2.17.1",
    "lucide-react": "^0.555.0",
    "zustand": "^5.0.8",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "vite": "^7.2.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  },
  "build": {
    "appId": "com.discord2.desktop",
    "productName": "Discord2",
    "electronVersion": "39.2.7",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.social-networking",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Network",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
