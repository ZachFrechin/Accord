NODE_ENV=development

SUPABASE_URL=https://supabase.example.com
# Optional. Use only when it points to the same Supabase/Kong base URL reachable
# from the API container. Do not point this to a raw GoTrue/Auth subpath.
SUPABASE_INTERNAL_URL=
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
# Recommended in production: copy the JWT secret from Supabase Auth settings.
# It must match the instance that issued the client access tokens.
SUPABASE_JWT_SECRET=replace-me

API_PORT=4000
API_CORS_ORIGINS=http://localhost:5173
API_BODY_LIMIT=1mb

GATEWAY_PORT=4001
GATEWAY_CORS_ORIGINS=http://localhost:5173
REDIS_URL=redis://redis:6379

LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me

VITE_SUPABASE_URL=https://supabase.example.com
VITE_SUPABASE_ANON_KEY=replace-me
VITE_API_URL=http://localhost:4000
VITE_GATEWAY_URL=http://localhost:4001
VITE_LIVEKIT_URL=wss://livekit.example.com
